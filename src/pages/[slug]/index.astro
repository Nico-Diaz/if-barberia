---
// src/pages/[slug]/index.astro
export const prerender = true; // Soluciona el error de getStaticPaths en Vercel

import Layout from '../../layouts/Layout.astro';
import BookingSection from '../../components/BookingSection.astro';
import { createClient } from '@supabase/supabase-js';

// 1. GENERAR RUTAS ESTÁTICAS
export async function getStaticPaths() {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL, 
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY // Usamos la ANON_KEY
  );
  const { data: negocios } = await supabase.from('negocios').select('slug');
  return negocios ? negocios.map((n: { slug: string }) => ({ params: { slug: n.slug } })) : [];
}

// 2. OBTENER DATOS
const { slug } = Astro.params;

// IMPORTANTE: Asegúrate que estos nombres coincidan con tu archivo .env
const url = import.meta.env.PUBLIC_SUPABASE_URL;
const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const supabase = createClient(url, key);

const { data: negocio } = await supabase.from('negocios').select('*').eq('slug', slug).single();

if (!negocio) return Astro.redirect('/404');

const { data: servicios } = await supabase.from('servicios').select('*').eq('negocio_id', negocio.id).order('precio');
const { data: profesionales } = await supabase.from('profesionales').select('*').eq('negocio_id', negocio.id);

// Definimos si es veterinaria para cambiar el estilo
const esVete = negocio.rubro === 'veterinaria';
---

<Layout title={`Reserva en ${negocio.nombre}`}>
    <main class={`app-wrapper ${esVete ? 'tema-vete' : 'tema-barber'}`}>
        
        <div class="brand-header">
            {esVete && <span class="vete-icon">🐾</span>}
            <h1 class="font-bernier">{negocio.nombre}</h1>
            
            {esVete ? (
                <div class="vete-decorator" style={`background: ${negocio.color_primario || '#7C2D96'};`}></div>
            ) : (
                <div class="bar-decorator"></div>
            )}
            
            <p class="slogan">
                {esVete ? 'Cuidamos a quien más quieres' : 'Reserva tu lugar exclusivo'}
            </p>
        </div>
        
        <BookingSection 
            negocio={negocio} 
            servicios={servicios || []} 
            profesionales={profesionales || []} 
        />
        
        <footer class="mini-footer">
            <p>© 2026 {negocio.nombre}</p>
        </footer>
    </main>
</Layout>

<style is:global>
    /* 1. RESET TOTAL */
    html, body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        min-height: 100vh !important;
        overflow-x: hidden;
    }

    /* 2. EL FONDO DE POSTE DE BARBERÍA (Diagonal Stripes) */
    .tema-barber {
        background-color: #0f172a !important; /* Color de fondo base oscuro */
        background-image: repeating-linear-gradient(
            45deg,
            rgba(217, 37, 37, 0.08),       /* Rojo muy sutil */
            rgba(217, 37, 37, 0.08) 40px,
            rgba(255, 255, 255, 0.05) 40px, /* Blanco muy sutil */
            rgba(255, 255, 255, 0.05) 80px,
            rgba(30, 58, 138, 0.08) 80px,  /* Azul muy sutil */
            rgba(30, 58, 138, 0.08) 120px,
            rgba(255, 255, 255, 0.05) 120px,
            rgba(255, 255, 255, 0.05) 160px
        ) !important;
        background-attachment: fixed; /* Esto hace que las líneas no se muevan al hacer scroll */
    }

    /* 3. CONTENEDOR PRINCIPAL */
    .app-wrapper { 
        min-height: 100vh; 
        width: 100%; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
        padding: 40px 15px; 
        box-sizing: border-box;
    }

    /* 4. CABECERA UNIFORME */
    .brand-header { 
        text-align: center; 
        margin-bottom: 30px; 
        width: 100%; 
    }

    .font-bernier {
        font-family: 'Bernier', 'Bebas Neue', sans-serif !important;
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin: 0;
        line-height: 1;
        /* Sombra para que resalte sobre las líneas del fondo */
        text-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

    .tema-barber h1 { font-size: 3.5rem; font-weight: 900; }

    /* 5. EL DECORADOR (Cápsula de Poste) */
    .bar-decorator {
        height: 14px; 
        width: 120px; 
        margin: 15px auto; 
        border-radius: 50px; 
        border: 2px solid white;
        background: repeating-linear-gradient(
            45deg, 
            #D92525, 
            #D92525 15px, 
            #ffffff 15px, 
            #ffffff 25px, 
            #1E3A8A 25px, 
            #1E3A8A 40px
        );
        box-shadow: 0 5px 20px rgba(0,0,0,0.4);
    }

    .slogan { 
        color: rgba(255,255,255,0.8); 
        font-size: 1.1rem; 
        margin-top: 10px; 
        font-weight: 500;
    }

    /* 6. PIE DE PÁGINA */
    .mini-footer { 
        margin-top: 40px; 
        color: rgba(255,255,255,0.2); 
        font-size: 0.8rem; 
    }

    /* RESPONSIVE */
    @media (max-width: 600px) {
        .tema-barber h1 { font-size: 2.5rem; }
        .app-wrapper { justify-content: flex-start; padding-top: 30px; }
    }
</style>