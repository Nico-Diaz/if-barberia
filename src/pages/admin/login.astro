---
// src/pages/admin/login.astro
import Layout from '../../layouts/Layout.astro';

// 1. CAPTURAMOS LAS VARIABLES EN EL SERVIDOR (Aquí sí funciona import.meta.env)
const SITE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SITE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<Layout title="Admin Login">
    <div class="login-wrapper">
        <div class="login-card">
            <div class="brand-header">
                <h1>Admin Panel</h1>
                <div class="barber-stripe"></div>
            </div>

            <form id="login-form">
                <div class="input-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="admin@ejemplo.com" required>
                </div>
                
                <div class="input-group">
                    <label>Contraseña</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>

                <div id="error-msg" class="error-msg" style="display: none;"></div>

                <button type="submit" id="btn-login">INGRESAR 🔐</button>
            </form>
        </div>
    </div>
</Layout>

<script define:vars={{ SITE_URL, SITE_KEY }} type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';

    // 3. USAMOS LAS VARIABLES DIRECTAMENTE (Ya no usamos import.meta.env aquí)
    const supabase = createClient(SITE_URL, SITE_KEY);

    const form = document.getElementById('login-form');
    const btn = document.getElementById('btn-login');
    const errorMsg = document.getElementById('error-msg');

    // VALIDACIÓN DE SEGURIDAD (Evita errores si el DOM no cargó)
    if (!form || !btn || !errorMsg) {
        throw new Error("Elementos del login no encontrados");
    }

    // VERIFICAR SESIÓN ACTIVA
    async function checkSession() {
        const { data } = await supabase.auth.getSession();
        if (data.session) {
            // Si ya hay sesión, intentar ir al último dashboard visitado
            const lastSlug = localStorage.getItem('last_admin_slug');
            if(lastSlug) {
                window.location.href = `/admin/${lastSlug}/dashboard`;
            } else {
                // Buscar un negocio que pertenezca a este usuario específico
                const { data: negocios } = await supabase.from('negocios').select('slug').eq('user_id', data.session.user.id).limit(1);
                if (negocios && negocios.length > 0) {
                    window.location.href = `/admin/${negocios[0].slug}/dashboard`;
                } else {
                    console.log("Sesión activa pero no tienes negocios asignados a tu cuenta.");
                }
            }
        }
    }
    checkSession();

    // LÓGICA DE LOGIN
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        btn.disabled = true;
        btn.innerText = "Verificando...";
        errorMsg.style.display = 'none';

        // Usamos FormData para obtener los valores de forma segura
        const formData = new FormData(form);
        const email = formData.get('email');
        const password = formData.get('password');

        const { data, error } = await supabase.auth.signInWithPassword({
            email: email,
            password: password
        });

        if (error) {
            errorMsg.innerText = "❌ Credenciales incorrectas";
            errorMsg.style.display = 'block';
            btn.disabled = false;
            btn.innerText = "INGRESAR 🔐";
        } else {
            btn.innerText = "¡Éxito!";
            btn.style.background = "#22c55e"; // Verde éxito
            
            // REDIRECCIÓN INTELIGENTE
            const redirectUrl = localStorage.getItem('redirect_after_login');
            
            if (redirectUrl) {
                localStorage.removeItem('redirect_after_login');
                window.location.href = redirectUrl;
            } else {
                // Si entró directo al login sin intentar ir a un dashboard específico
                const lastSlug = localStorage.getItem('last_admin_slug');
                if (lastSlug) {
                     window.location.href = `/admin/${lastSlug}/dashboard`;
                } else {
                    // Buscar un negocio que pertenezca a este usuario específico
                    const userId = data.user.id;
                    
                    if (userId) {
                        const { data: negocios, error: negError } = await supabase.from('negocios').select('slug').eq('user_id', userId).limit(1);
                        
                        if (negocios && negocios.length > 0) {
                            window.location.href = `/admin/${negocios[0].slug}/dashboard`;
                            return;
                        } else {
                            console.log("Error consultando negocios:", negError);
                        }
                    }
                    alert("Login correcto pero no tienes negocios asignados a tu cuenta de Supabase. (UserID: " + userId + ")");
                }
            }
        }
    });
</script>

<style is:global>
    /* ESTILOS GLOBALES */
    :root { --bg-dark: #0f172a; --bg-card: #1e293b; --barber-red: #D92525; --barber-blue: #1E3A8A; --text-muted: #94a3b8; }

    body {
        margin: 0; padding: 0; width: 100%; min-height: 100vh;
        background-color: var(--bg-dark);
        font-family: system-ui, sans-serif;
        display: flex; justify-content: center; align-items: center;
        /* Fondo con patrón sutil */
        background-image: linear-gradient(45deg, rgba(217, 37, 37, 0.05) 25%, transparent 25%, transparent 50%, rgba(30, 58, 138, 0.05) 50%, rgba(30, 58, 138, 0.05) 75%, transparent 75%, transparent);
        background-size: 60px 60px;
    }
</style>

<style>
    /* ESTILOS DE LA TARJETA */
    .login-wrapper { width: 100%; padding: 20px; display: flex; justify-content: center; }
    
    .login-card { 
        background: var(--bg-card); padding: 2.5rem; border-radius: 1.5rem; 
        width: 100%; max-width: 400px; 
        box-shadow: 0 20px 50px rgba(0,0,0,0.5); 
        border: 1px solid rgba(255,255,255,0.1);
    }

    .brand-header { text-align: center; margin-bottom: 30px; }
    .brand-header h1 { color: white; margin: 0; text-transform: uppercase; letter-spacing: 2px; font-size: 1.5rem; }
    .barber-stripe { height: 6px; width: 80px; margin: 15px auto; background: repeating-linear-gradient(45deg, var(--barber-red), var(--barber-red) 10px, white 10px, white 20px, var(--barber-blue) 20px, var(--barber-blue) 30px, white 30px, white 40px); border-radius: 4px; }

    .input-group { margin-bottom: 20px; }
    label { display: block; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 8px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; }
    
    input { width: 100%; background: #0f172a; border: 1px solid #334155; color: white; padding: 14px; border-radius: 8px; font-size: 1rem; outline: none; box-sizing: border-box; transition: 0.2s; }
    input:focus { border-color: var(--barber-blue); box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.2); }

    button { width: 100%; padding: 16px; background: var(--barber-blue); color: white; border: none; border-radius: 8px; font-weight: bold; font-size: 1rem; cursor: pointer; transition: 0.2s; margin-top: 10px; text-transform: uppercase; letter-spacing: 1px; }
    button:hover { filter: brightness(1.2); transform: translateY(-1px); }
    button:disabled { opacity: 0.7; cursor: wait; transform: none; }
    
    .error-msg { background: rgba(239, 68, 68, 0.15); color: #ef4444; padding: 12px; border-radius: 8px; text-align: center; margin-bottom: 20px; border: 1px solid rgba(239, 68, 68, 0.3); font-weight: bold; font-size: 0.9rem; }
</style>