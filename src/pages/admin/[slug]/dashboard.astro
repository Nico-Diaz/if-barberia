---
// src/pages/admin/[slug]/dashboard.astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;

// Conexión Supabase
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

const { data: negocio } = await supabase.from('negocios').select('*').eq('slug', slug).single();

if (!negocio) return Astro.redirect('/404');

const NEGOCIO_ID = negocio.id;
const SLUG = negocio.slug;
---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>

<Layout title={`Admin - ${negocio.nombre}`}>
    <main class="dashboard-wrapper" style="display: none;" id="main-admin">
        
        <header class="top-bar">
            <div class="container bar-content">
                <div class="brand">
                    <div class="brand-icon">⚡</div>
                    <div class="brand-info">
                        <h1>Panel de Control</h1>
                        <span>{negocio.nombre}</span>
                    </div>
                </div>
                <button id="btn-logout" class="btn-ghost">
                    Cerrar Sesión <span class="icon">➜</span>
                </button>
            </div>
        </header>

        <nav class="nav-tabs-wrapper">
            <div class="container nav-container">
                <button class="nav-tab active" id="btn-turnos">📅 Agenda</button>
                <button class="nav-tab" id="btn-servicios">💰 Servicios</button>
                <button class="nav-tab" id="btn-equipo">💈 Equipo</button>
                <button class="nav-tab" id="btn-bloqueos">⛔ Bloqueos</button>
            </div>
        </nav>

        <div class="container content-area">
            
            <section id="tab-turnos" class="tab-section active">
                <div class="section-header">
                    <h2>Próximos Turnos</h2>
                    <button id="refresh-turnos" class="btn-action primary">🔄 Actualizar</button>
                </div>
                <div id="lista-turnos" class="grid-agenda">
                    <div class="loading-spinner">Cargando agenda...</div>
                </div>
            </section>

            <section id="tab-servicios" class="tab-section">
                <div class="section-header">
                    <h2>Mis Servicios</h2>
                    <p>Configura precios y títulos.</p>
                </div>
                
                <div class="card-panel">
                    <form id="form-add-servicio" class="inline-form">
                        <input type="text" name="nombre" placeholder="Nombre (Ej: Corte Clásico)" required>
                        <input type="number" name="precio" placeholder="$ Precio" required class="short-input">
                        <button type="submit" class="btn-action success">➕ Agregar</button>
                    </form>
                </div>

                <div id="lista-servicios" class="list-stack"></div>
            </section>

            <section id="tab-equipo" class="tab-section">
                <div class="section-header">
                    <h2>Equipo de Trabajo</h2>
                    <p>Gestiona profesionales y sus horarios.</p>
                </div>

                <div class="card-panel">
                    <form id="form-add-barbero" class="inline-form">
                        <input type="text" name="nombre" placeholder="Nombre del profesional..." required>
                        <button type="submit" class="btn-action success">➕ Nuevo Profesional</button>
                    </form>
                </div>

                <div id="lista-barberos" class="cards-stack"></div>
            </section>

            <section id="tab-bloqueos" class="tab-section">
                <div class="section-header">
                    <h2>Días Cerrados</h2>
                </div>

                <div class="cols-2">
                    <div class="card-panel">
                        <h3>Bloquear Fecha</h3>
                        <p class="text-sm">Elige un día para cerrar la agenda.</p>
                        <div class="block-form">
                            <input type="text" id="fecha-bloqueo" placeholder="Seleccionar día..." class="input-date" readonly>
                            <button id="btn-bloquear" class="btn-action danger full-width">⛔ Bloquear Día</button>
                        </div>
                    </div>
                    
                    <div class="card-panel">
                        <h3>Historial</h3>
                        <ul id="lista-bloqueos" class="simple-list"></ul>
                    </div>
                </div>
            </section>

        </div>
    </main>
</Layout>

<script type="module" define:vars={{ supabaseUrl, supabaseKey, NEGOCIO_ID, SLUG }}>
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm';
    const supabase = createClient(supabaseUrl, supabaseKey);

    // --- AUTH CHECK ---
    async function checkAuth() {
        const { data: { session } } = await supabase.auth.getSession();
        if (!session) {
            localStorage.setItem('redirect_after_login', window.location.href);
            window.location.href = '/admin/login';
        } else {
            localStorage.setItem('last_admin_slug', SLUG); // Guardar el slug para redirección futura desde login
            document.getElementById('main-admin').style.display = 'block';
            initDashboard();
        }
    }
    checkAuth();

    // --- DOM REFS ---
    const listaTurnos = document.getElementById('lista-turnos');
    const listaServicios = document.getElementById('lista-servicios');
    const listaBarberos = document.getElementById('lista-barberos');
    const listaBloqueos = document.getElementById('lista-bloqueos');

    function initDashboard() {
        if(typeof flatpickr !== 'undefined') {
            flatpickr("#fecha-bloqueo", { locale: "es", dateFormat: "Y-m-d", minDate: "today", disableMobile: true, theme: "dark" });
        }
        cargarTurnos(); cargarServicios(); cargarBarberos(); cargarBloqueos();
    }

    // --- 1. TURNOS ---
    async function cargarTurnos() {
        listaTurnos.innerHTML = '<div class="loading-spinner">Cargando...</div>';
        const hoy = new Date().toISOString().split('T')[0];
        const { data, error } = await supabase.from('turnos').select('*').eq('negocio_id', NEGOCIO_ID).gte('fecha', hoy).order('fecha').order('hora');
        
        if (error || !data || data.length === 0) { 
            listaTurnos.innerHTML = `
                <div class="empty-state">
                    <div class="icon">🍃</div>
                    <h3>Agenda Libre</h3>
                    <p>No hay turnos próximos agendados.</p>
                </div>`; 
            return; 
        }

        listaTurnos.innerHTML = data.map(t => {
            const tel = t.cliente_telefono ? t.cliente_telefono.replace(/\D/g, '') : '';
            const titulo = t.mascota_nombre ? `🐾 ${t.mascota_nombre} <small>(${t.cliente_nombre})</small>` : `${t.cliente_nombre} ${t.cliente_apellido || ''}`;
            const fecha = t.fecha.split('-').reverse().join('/');
            const wspLink = tel ? `https://wa.me/549${tel}` : '#';

            return `
            <div class="turno-card">
                <div class="card-top">
                    <div class="date-badge">
                        <span class="day">${fecha}</span>
                        <span class="time">${t.hora.slice(0,5)} hs</span>
                    </div>
                    <span class="service-badge">${t.servicio}</span>
                </div>
                <div class="card-main">
                    <h4>${titulo}</h4>
                    <span class="pro-name">👨‍⚕️ ${t.profesional}</span>
                </div>
                <div class="card-actions">
                    ${tel ? `<a href="${wspLink}" target="_blank" class="btn-icon whatsapp" title="WhatsApp">📱</a>` : ''}
                    <button class="btn-icon delete" data-action="delete-turno" data-id="${t.id}" title="Cancelar">🗑️</button>
                </div>
            </div>`;
        }).join('');
    }

    // --- 2. SERVICIOS ---
    async function cargarServicios() {
        const { data } = await supabase.from('servicios').select('*').eq('negocio_id', NEGOCIO_ID).order('precio');
        listaServicios.innerHTML = data ? data.map(s => `
            <div class="list-row">
                <div class="inputs-group">
                    <input type="text" value="${s.nombre}" id="name-${s.id}" class="clean-input">
                    <div class="price-input-wrapper">
                        <span>$</span>
                        <input type="number" value="${s.precio}" id="price-${s.id}" class="clean-input short">
                    </div>
                </div>
                <div class="row-actions">
                    <button class="btn-icon save" data-action="save-servicio" data-id="${s.id}">💾</button>
                    <button class="btn-icon delete" data-action="delete-servicio" data-id="${s.id}">🗑️</button>
                </div>
            </div>
        `).join('') : '<p class="text-center">Sin servicios.</p>';
    }

    // --- 3. EQUIPO ---
    async function cargarBarberos() {
        const { data } = await supabase.from('profesionales').select('*').eq('negocio_id', NEGOCIO_ID).order('created_at');
        listaBarberos.innerHTML = data ? data.map(p => {
            const defH = {"1":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"2":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"3":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"4":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"5":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"6":{"i":"10:00","f":"20:00","activo":true,"di":"","df":""},"0":{"i":"10:00","f":"20:00","activo":false,"di":"","df":""}};
            const h = p.horarios || defH;
            const dias = [{k:"1",l:"Lunes"},{k:"2",l:"Martes"},{k:"3",l:"Miér"},{k:"4",l:"Jueves"},{k:"5",l:"Viernes"},{k:"6",l:"Sábado"},{k:"0",l:"Dom"}];

            const grid = dias.map(d => {
                const dd = h[d.k] || {i: "10:00", f: "20:00", activo: false, di: "", df: ""};
                return `
                <div class="day-config ${dd.activo ? 'active' : ''}">
                    <label class="day-label">
                        <input type="checkbox" id="check-${p.id}-${d.k}" ${dd.activo?'checked':''} class="toggle-day">
                        ${d.l}
                    </label>
                    <div class="time-inputs">
                        <input type="time" value="${dd.i}" id="ini-${p.id}-${d.k}" ${!dd.activo?'disabled':''} title="Hora de inicio">
                        <span>a</span>
                        <input type="time" value="${dd.f}" id="fin-${p.id}-${d.k}" ${!dd.activo?'disabled':''} title="Hora de fin">
                    </div>
                    <div class="break-inputs" style="margin-top: 10px; opacity: ${dd.activo ? '1' : '0.5'};">
                        <small style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-bottom: 5px;">Descanso (opcional)</small>
                        <div class="time-inputs">
                            <input type="time" value="${dd.di || ''}" id="desc-ini-${p.id}-${d.k}" ${!dd.activo?'disabled':''} title="Inicio descanso">
                            <span>a</span>
                            <input type="time" value="${dd.df || ''}" id="desc-fin-${p.id}-${d.k}" ${!dd.activo?'disabled':''} title="Fin descanso">
                        </div>
                    </div>
                </div>`;
            }).join('');

            return `
            <div class="pro-card">
                <div class="pro-header">
                    <div class="pro-info">
                        <span class="avatar">👤</span>
                        <input type="text" value="${p.nombre}" id="barb-${p.id}" class="clean-input big">
                    </div>
                    <div class="pro-actions">
                        <button class="btn-small outline" data-action="toggle-week" data-id="${p.id}">📅 Horarios</button>
                        <button class="btn-icon save" data-action="save-barbero" data-id="${p.id}">💾</button>
                        <button class="btn-icon delete" data-action="delete-barbero" data-id="${p.id}">🗑️</button>
                    </div>
                </div>
                <div id="week-${p.id}" class="week-panel"><div class="week-grid">${grid}</div></div>
            </div>`;
        }).join('') : '';
    }

    // --- 4. BLOQUEOS ---
    async function cargarBloqueos() {
        const hoy = new Date().toISOString().split('T')[0];
        const { data } = await supabase.from('dias_especiales').select('*').eq('negocio_id', NEGOCIO_ID).gte('fecha', hoy);
        listaBloqueos.innerHTML = data ? data.map(d => `
            <li class="list-row-simple">
                <span>📅 ${d.fecha.split('-').reverse().join('/')}</span>
                <button class="btn-icon delete" data-action="delete-bloqueo" data-id="${d.id}">🗑️</button>
            </li>`).join('') : '<p class="text-center text-sm">No hay bloqueos.</p>';
    }

    // --- EVENTOS CLICK ---
    document.getElementById('btn-logout').addEventListener('click', async () => { if(confirm('¿Cerrar sesión?')) { await supabase.auth.signOut(); window.location.href = '/admin/login'; } });

    // Tabs
    const tabs = document.querySelectorAll('.nav-tab');
    const sections = document.querySelectorAll('.tab-section');
    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            sections.forEach(s => s.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById(btn.id.replace('btn-', 'tab-')).classList.add('active');
        });
    });

    // Delegación Global
    document.body.addEventListener('click', async (e) => {
        // Toggle checkboxes día
        if(e.target.classList.contains('toggle-day')) {
            const container = e.target.closest('.day-config');
            container.classList.toggle('active', e.target.checked);
            container.querySelectorAll('input[type="time"]').forEach(i => i.disabled = !e.target.checked);
            const breakInputs = container.querySelector('.break-inputs');
            if(breakInputs) breakInputs.style.opacity = e.target.checked ? '1' : '0.5';
        }

        const btn = e.target.closest('button');
        if(!btn || !btn.dataset.action) return;
        const act = btn.dataset.action; const id = btn.dataset.id;

        try {
            if(act === 'delete-turno' && confirm('¿Cancelar turno?')) { await supabase.from('turnos').delete().eq('id', id); cargarTurnos(); }
            else if(act === 'save-servicio') { await supabase.from('servicios').update({ nombre: document.getElementById(`name-${id}`).value, precio: document.getElementById(`price-${id}`).value }).eq('id', id); alert('Servicio actualizado'); }
            else if(act === 'delete-servicio' && confirm('¿Borrar?')) { await supabase.from('servicios').delete().eq('id', id); cargarServicios(); }
            else if(act === 'toggle-week') { 
                const p = document.getElementById(`week-${id}`); p.style.display = p.style.display==='block'?'none':'block'; 
                btn.classList.toggle('active');
            }
            else if(act === 'save-barbero') {
                const nombre = document.getElementById(`barb-${id}`).value;
                let h = {};
                // Recorremos dias 0-6
                for(let i=0; i<=6; i++) {
                    const k = i.toString(); const chk = document.getElementById(`check-${id}-${k}`);
                    if(chk) h[k] = { 
                        activo: chk.checked, 
                        i: document.getElementById(`ini-${id}-${k}`).value, 
                        f: document.getElementById(`fin-${id}-${k}`).value,
                        di: document.getElementById(`desc-ini-${id}-${k}`).value,
                        df: document.getElementById(`desc-fin-${id}-${k}`).value
                    };
                }
                await supabase.from('profesionales').update({ nombre, horarios: h }).eq('id', id); alert('Horarios guardados');
            }
            else if(act === 'delete-barbero' && confirm('¿Borrar profesional?')) { await supabase.from('profesionales').delete().eq('id', id); cargarBarberos(); }
            else if(act === 'delete-bloqueo') { await supabase.from('dias_especiales').delete().eq('id', id); cargarBloqueos(); }

        } catch(err) { console.error(err); alert('Error: ' + err.message); }
    });

    // Submit Forms
    document.getElementById('form-add-servicio').addEventListener('submit', async(e)=>{ e.preventDefault(); const f=new FormData(e.target); await supabase.from('servicios').insert({negocio_id:NEGOCIO_ID, nombre:f.get('nombre'), precio:f.get('precio')}); e.target.reset(); cargarServicios(); });
    document.getElementById('form-add-barbero').addEventListener('submit', async(e)=>{ e.preventDefault(); const f=new FormData(e.target); await supabase.from('profesionales').insert({negocio_id:NEGOCIO_ID, nombre:f.get('nombre')}); e.target.reset(); cargarBarberos(); });
    document.getElementById('btn-bloquear').addEventListener('click', async()=>{ const v=document.getElementById('fecha-bloqueo').value; if(v){ await supabase.from('dias_especiales').insert({negocio_id:NEGOCIO_ID, fecha:v, cerrado:true}); cargarBloqueos(); }});
    document.getElementById('refresh-turnos').addEventListener('click', cargarTurnos);
</script>

<style is:global>
    /* 1. VARIABLES DE DISEÑO "PIOLA" */
    :root {
        --bg-main: #0f172a;       /* Fondo General Oscuro */
        --bg-card: #1e293b;       /* Fondo de Tarjetas */
        --bg-input: #334155;      /* Fondo Inputs */
        
        --primary: #3b82f6;       /* Azul Brillante */
        --success: #10b981;       /* Verde Neon */
        --danger: #ef4444;        /* Rojo Alerta */
        --text-main: #f1f5f9;     /* Blanco Humo */
        --text-muted: #94a3b8;    /* Gris Texto Secundario */
        
        --border-radius: 12px;
        --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
    }

    /* 2. RESET GLOBAL */
    html, body { margin: 0; padding: 0; background: var(--bg-main); color: var(--text-main); font-family: 'Inter', system-ui, sans-serif; font-size: 16px; overflow-x: hidden; width: 100%; }
    * { box-sizing: border-box; }
    button, input { border: none; outline: none; font-family: inherit; }

    /* 3. LAYOUT */
    .dashboard-wrapper { width: 100%; min-height: 100vh; display: flex; flex-direction: column; }
    .container { max-width: 1100px; margin: 0 auto; width: 100%; padding: 0 20px; }

    /* 4. HEADER */
    .top-bar { background: var(--bg-card); border-bottom: 1px solid #334155; padding: 1rem 0; }
    .bar-content { display: flex; justify-content: space-between; align-items: center; }
    
    .brand { display: flex; align-items: center; gap: 12px; }
    .brand-icon { font-size: 1.8rem; background: rgba(59, 130, 246, 0.1); width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: var(--primary); }
    .brand-info h1 { margin: 0; font-size: 1.1rem; font-weight: 700; }
    .brand-info span { font-size: 0.85rem; color: var(--text-muted); }

    .btn-ghost { background: transparent; color: var(--text-muted); cursor: pointer; padding: 8px 16px; border-radius: 8px; font-weight: 500; transition: 0.2s; border: 1px solid transparent; }
    .btn-ghost:hover { border-color: var(--danger); color: var(--danger); background: rgba(239, 68, 68, 0.1); }

    /* 5. NAVEGACIÓN (TABS) */
    .nav-tabs-wrapper { background: rgba(15, 23, 42, 0.95); position: sticky; top: 0; z-index: 100; border-bottom: 1px solid #334155; backdrop-filter: blur(5px); margin-bottom: 30px; }
    .nav-container { display: flex; gap: 10px; overflow-x: auto; padding-top: 15px; padding-bottom: 0; }
    .nav-tab {
        background: transparent; color: var(--text-muted); padding: 12px 20px; font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: 0.3s; white-space: nowrap;
    }
    .nav-tab:hover { color: white; }
    .nav-tab.active { color: var(--primary); border-bottom-color: var(--primary); }

    /* 6. CONTENIDO */
    .tab-section { display: none; animation: fadeIn 0.4s ease; padding-bottom: 50px; }
    .tab-section.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 1px solid #334155; padding-bottom: 15px; }
    .section-header h2 { margin: 0; font-size: 1.5rem; }
    .section-header p { margin: 5px 0 0; color: var(--text-muted); font-size: 0.9rem; }

    /* 7. TARJETAS Y PANELES */
    .card-panel { background: var(--bg-card); padding: 25px; border-radius: var(--border-radius); box-shadow: var(--shadow-card); margin-bottom: 25px; border: 1px solid #334155; }
    
    .inline-form { display: flex; gap: 15px; flex-wrap: wrap; }
    
    /* INPUTS */
    input { background: var(--bg-input); color: white; padding: 12px 16px; border-radius: 8px; border: 1px solid transparent; font-size: 1rem; flex: 1; transition: 0.2s; }
    input:focus { border-color: var(--primary); background: #1e293b; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2); }
    .short-input { max-width: 120px; text-align: center; }
    .input-date { text-align: center; cursor: pointer; font-weight: bold; }

    /* 8. BOTONES DE ACCIÓN */
    .btn-action {
        padding: 12px 24px; border-radius: 8px; font-weight: 700; cursor: pointer; color: white; transition: transform 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-action:hover { transform: translateY(-2px); filter: brightness(1.1); }
    .btn-action.success { background: var(--success); }
    .btn-action.danger { background: var(--danger); }
    .btn-action.primary { background: var(--primary); }
    .full-width { width: 100%; }

    .btn-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1.2rem; transition: 0.2s; }
    .btn-icon:hover { transform: scale(1.1); }
    .btn-icon.delete { background: rgba(239, 68, 68, 0.15); color: var(--danger); }
    .btn-icon.delete:hover { background: var(--danger); color: white; }
    .btn-icon.save { background: rgba(59, 130, 246, 0.15); color: var(--primary); }
    .btn-icon.save:hover { background: var(--primary); color: white; }
    .btn-icon.whatsapp { background: #25D366; color: white; }

    /* 9. GRILLA DE AGENDA (TURNOS) */
    .grid-agenda { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .turno-card {
        background: var(--bg-card); border-radius: var(--border-radius); padding: 20px;
        border-left: 4px solid var(--primary); box-shadow: var(--shadow-card);
        display: flex; flex-direction: column; justify-content: space-between; gap: 15px;
        transition: 0.2s;
    }
    .turno-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

    .card-top { display: flex; justify-content: space-between; align-items: flex-start; }
    .date-badge { display: flex; flex-direction: column; align-items: center; background: #334155; padding: 5px 10px; border-radius: 6px; }
    .date-badge .day { font-size: 0.8rem; font-weight: bold; color: #cbd5e1; }
    .date-badge .time { font-size: 1.1rem; font-weight: 800; color: white; }
    .service-badge { background: rgba(59, 130, 246, 0.1); color: #60a5fa; padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: 600; text-align: right; }

    .card-main h4 { margin: 0 0 5px 0; font-size: 1.1rem; }
    .pro-name { color: var(--text-muted); font-size: 0.9rem; }
